{
  "project_name": "PulseRank",
  "version": "v0.1.0",
  "truth_boundary": {
    "build_type": "solo-built_non-production_production-simulated",
    "not_claimed": [
      "real production deployment",
      "real users served",
      "real production traffic",
      "real online A/B test",
      "real revenue optimization",
      "real RL or contextual bandit optimization",
      "real ad auction system"
    ]
  },
  "corpus": {
    "simulated_days": 90,
    "random_seed": 20260505,
    "train_days": [1, 60],
    "holdout_days": [61, 90]
  },
  "ranking": {
    "candidate_set_size": 100,
    "final_rank_k": 10,
    "baseline_candidate_generators": [
      "popularity",
      "content_similarity"
    ],
    "primary_ranker": "logistic_regression_or_lightgbm_baseline",
    "two_tower_retrieval": "should_have_not_core_v1"
  },
  "position_bias": {
    "propensity_floor": 0.01,
    "display_rank_required": true,
    "default_propensity_by_rank": {
      "1": 0.25,
      "2": 0.21,
      "3": 0.18,
      "4": 0.15,
      "5": 0.12,
      "6": 0.10,
      "7": 0.085,
      "8": 0.075,
      "9": 0.065,
      "10": 0.06
    }
  },
  "reranking": {
    "mmr_lambda": 0.7,
    "seller_gini_threshold": 0.65,
    "category_top10_max_share": 0.5,
    "ild_floor": 0.30,
    "catalog_daily_coverage_floor": 0.10
  },
  "exploration": {
    "epsilon": 0.05,
    "allowed_deviation_pp": 0.02,
    "hard_cap": 0.15
  },
  "attribution": {
    "default_window_days": 3,
    "sensitivity_windows_days": [1, 3, 7],
    "return_window_days": 14,
    "null_safe_aggregation": true
  },
  "promotion_gates": {
    "temporal_holdout_required": true,
    "bias_correction_report_required": true,
    "delayed_attribution_required": true,
    "seller_exposure_report_required": true,
    "ab_simulation_required": true,
    "show_demo_report_required": true
  }
}
